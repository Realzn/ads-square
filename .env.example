# ═══════════════════════════════════════════════════════════════
# AdsMostFair — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local
# Toutes ces variables doivent être dans Cloudflare Pages en production
# ═══════════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...          # webhook /api/stripe/webhook
STRIPE_WEBHOOK_SECRET_SUB=whsec_...      # webhook /api/stripe/webhook-subscription

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=AdsMostFair <noreply@adsmostfair.com>
EMAIL_FROM=AdsMostFair <noreply@adsmostfair.com>  # utilisé par lib/emails.js

# ── URLs ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://adsmostfair.com
NEXT_PUBLIC_SITE_URL=https://adsmostfair.com      # utilisé par Stripe redirects

# ── Sécurité ───────────────────────────────────────────────────
ADMIN_SECRET=...          # mot de passe admin panel
ADMIN_EMAIL=...           # email alertes admin
CRON_SECRET=...           # token Bearer pour sécuriser les routes /api/cron/*
